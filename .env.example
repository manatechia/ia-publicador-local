# Copiá este archivo como .env y completá lo que uses.
# Proveedor por defecto si el proyecto no define uno: claudecode | ollama | anthropic | openai
DEFAULT_PROVIDER=claudecode

# --- Claude Code (local, usa tu suscripción, SIN API key) ---
# Requiere tener Claude Code instalado y autenticado (claude setup-token).
# IMPORTANTE: para que use la suscripción y no la API, dejá ANTHROPIC_API_KEY vacío.
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet

# --- Ollama (100% local, gratis) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Anthropic (opcional) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- OpenAI (opcional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Generador de imágenes (opcional; usa el primero configurado) ---
# Forzar proveedor: gemini | openai | sd  (vacío = auto-detecta)
IMAGE_PROVIDER=
# Gemini: key gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# OpenAI (usa OPENAI_API_KEY de arriba)
OPENAI_IMAGE_MODEL=gpt-image-1
# Stable Diffusion local (AUTOMATIC1111 con --api)
SD_URL=

# Puerto del servidor local
PORT=5173
